{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NAI Assistant",
  "version": "0.12.6",
  "identifier": "com.sunakgo.nai-assistant",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NAIS2 - NovelAI Image Studio",
        "width": 1600,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "csp": "default-src 'self'; img-src 'self' https: data: blob: asset: http://asset.localhost https://asset.localhost; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; style-src-attr 'self' 'unsafe-inline'; font-src 'self' https: data:; connect-src 'self' ipc: ipc://localhost ipc://* https: wss: http://ipc.localhost http://127.0.0.1:* http://* data: http://asset.localhost https://nais2-sync-worker.liuanjay.workers.dev https://hf-mirror.com https://huggingface.co https://cors.isteed.cc; frame-src 'self' https: data: blob: asset: http://asset.localhost http://localhost:*;"
    },
    "withGlobalTauri": true
  },
  "plugins": {
    "deep-link": {
      "schemes": [
        "nais2"
      ]
    },
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi",
      "dmg",
      "app"
    ],
    "resources": ["resources/data.db"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": null,
      "exceptionDomain": null
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "nsis/installer-hooks.nsh",
        "languages": ["SimpChinese", "TradChinese", "English"],
        "displayLanguageSelector": true
      }
    }
  }
}
